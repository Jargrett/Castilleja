bio_sum <- biomass %>%
group_by(removal) %>%
dplyr::summarise(mean = mean(total_no_cas, na.rm = TRUE),
se   = sd(total_no_cas, na.rm = TRUE) / sqrt(sum(!is.na(total_no_cas))),
.groups = "drop")
View(cast)
